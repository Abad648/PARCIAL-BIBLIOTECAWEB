@model Biblioteca.Models.Libro

<h2>Registrar Libro</h2>

<form asp-action="Create" method="post">

    <div>
        <label>Titulo</label>
        <input asp-for="Titulo" class="form-control" />
    </div>

    <div>
        <label>Publicacion</label>
        <input asp-for="Publicacion" class="form-control" />
    </div>

    <div>
        <label>Autor</label>
        <select asp-for="IdAutor" asp-items="ViewBag.Autores" class="form-control"></select>
    </div>

    <div>
        <label>Categoria</label>
        <select asp-for="IdCategoria" asp-items="ViewBag.Categorias" class="form-control"></select>
    </div>

    <br />

    <button type="submit" class="btn btn-success">Guardar</button>

</form>